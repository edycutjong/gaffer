models/
*.gguf

# QVAC / Pear local state
.qvac/
.pear/
corestore/
storage/

# Test & coverage artifacts
coverage/
.nyc_output/
test-results/

# OS noise
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
